# Required — used for JWT signing and API key hashing
SECRET_KEY=change-me-to-a-random-secret

# Required — PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://agentledger:agentledger@db:5432/agentledger

# Optional — allowed CORS origins (JSON array)
CORS_ORIGINS=["http://localhost:3000"]

# Optional — dashboard API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000/v1

# Stripe Issuing (optional — required for real virtual cards)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# 32-byte hex key for AES-256-GCM card detail encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CARD_ENCRYPTION_KEY=
